/**app.wxss**/
page {
  background: #f0f2f7;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

button {
  background: initial;
  border-radius: 0;
  padding: 0;
  margin: 0;
  line-height: normal;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* Shared utility */
.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}
