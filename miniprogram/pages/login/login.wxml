<!-- pages/login/login.wxml -->
<view class="page">
  <view wx:if="{{isReady}}">
    <!-- Brand Area -->
    <view class="brand">
      <view class="brand-logo">🏢</view>
      <text class="brand-title">会议室预约系统</text>
      <text class="brand-sub">高效协作，轻松预约</text>
    </view>

    <!-- Tab Switcher -->
    <view class="tabs">
      <view class="tab {{activeTab === 'login' ? 'active' : ''}}" data-tab="login" bindtap="switchTab">
        <text>登录</text>
      </view>
      <view class="tab {{activeTab === 'register' ? 'active' : ''}}" data-tab="register" bindtap="switchTab">
        <text>注册</text>
      </view>
      <view class="tab-indicator tab-indicator-{{activeTab}}"></view>
    </view>

    <!-- Login Form -->
    <view class="form-card" wx:if="{{activeTab === 'login'}}">
      <view class="input-group">
        <view class="input-label">手机号</view>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            data-key="phone"
            bindinput="bindLoginInput"
            value="{{loginForm.phone}}"
          />
        </view>
      </view>
      <view class="input-group">
        <view class="input-label">密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔑</text>
          <input
            class="input"
            password="true"
            maxlength="32"
            placeholder="请输入密码"
            data-key="password"
            bindinput="bindLoginInput"
            value="{{loginForm.password}}"
          />
        </view>
      </view>
      <button class="primary-btn" bindtap="bindPhone" loading="{{submitting}}">登录</button>
      <button class="link-btn" bindtap="switchTab" data-tab="register">没有账号？去注册 →</button>
    </view>

    <!-- Register Form -->
    <view class="form-card" wx:if="{{activeTab === 'register'}}">
      <view class="input-group">
        <view class="input-label">手机号</view>
        <view class="input-wrap">
          <text class="input-icon">📱</text>
          <input
            class="input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            data-key="phone"
            bindinput="bindRegisterInput"
            value="{{registerForm.phone}}"
          />
        </view>
      </view>
      <view class="input-group">
        <view class="input-label">昵称</view>
        <view class="input-wrap">
          <text class="input-icon">👤</text>
          <input
            class="input"
            type="text"
            maxlength="20"
            placeholder="请输入昵称"
            data-key="nickname"
            bindinput="bindRegisterInput"
            value="{{registerForm.nickname}}"
          />
        </view>
      </view>
      <view class="input-group">
        <view class="input-label">密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔑</text>
          <input
            class="input"
            password="true"
            maxlength="32"
            placeholder="至少6位"
            data-key="password"
            bindinput="bindRegisterInput"
            value="{{registerForm.password}}"
          />
        </view>
      </view>
      <view class="input-group">
        <view class="input-label">确认密码</view>
        <view class="input-wrap">
          <text class="input-icon">🔒</text>
          <input
            class="input"
            password="true"
            maxlength="32"
            placeholder="请再次输入密码"
            data-key="confirmPassword"
            bindinput="bindRegisterInput"
            value="{{registerForm.confirmPassword}}"
          />
        </view>
      </view>
      <button class="primary-btn register" bindtap="registerUser" loading="{{submitting}}">注册并登录</button>
      <button class="link-btn" bindtap="switchTab" data-tab="login">已有账号？去登录 →</button>
    </view>

    <!-- Footer -->
    <view class="footer">
      <button class="ghost-btn" bindtap="goBrowseHome">先去首页浏览活动</button>
    </view>
  </view>

  <view wx:else class="loading-state">
    <view class="loading-dot"></view>
    <text>加载中...</text>
  </view>
</view>
