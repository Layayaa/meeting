/* pages/admin/admin.wxss */
page {
  background: #f0f2f7;
  min-height: 100vh;
}

.page {
  padding-bottom: 60rpx;
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #1e40af, #7c3aed);
  padding: 60rpx 36rpx 50rpx;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
}

/* Menu */
.menu-list {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-wrap.blue { background: #eff6ff; }
.menu-icon-wrap.purple { background: #f5f3ff; }
.menu-icon-wrap.green { background: #f0fdf4; }
.menu-icon-wrap.orange { background: #fff7ed; }

.menu-emoji {
  font-size: 36rpx;
}

.menu-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.menu-desc {
  font-size: 22rpx;
  color: #9ca3af;
}

.arrow {
  font-size: 40rpx;
  color: #d1d5db;
}
