/* pages/initDatabase/initDatabase.wxss */
.page {
  padding: 20px;
}

.header {
  text-align: center;
  margin-bottom: 30px;
}

.title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.desc {
  font-size: 14px;
  color: #666;
  margin-bottom: 30px;
  text-align: center;
  line-height: 1.5;
}

.result {
  width: 100%;
  margin-bottom: 30px;
  padding: 15px;
  background-color: #f5f5f5;
  border-radius: 8px;
}

.result-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 10px;
  display: block;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.result-item {
  font-size: 14px;
  color: #666;
  display: block;
}

.action-btn {
  background-color: #07c160;
  color: white;
  border: none;
  border-radius: 8px;
  padding: 12px 24px;
  font-size: 16px;
  min-width: 120px;
}