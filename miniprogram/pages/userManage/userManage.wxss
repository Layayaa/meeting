/* pages/userManage/userManage.wxss */
page {
  background: #f0f2f7;
  min-height: 100vh;
}

.page {
  padding: 0 24rpx 60rpx;
}

/* Section Header */
.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* Form Card */
.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.input-group {
  margin-bottom: 22rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.optional {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 400;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.add-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 8rpx;
  border: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* User Card */
.user-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb, #7c3aed);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.user-dept {
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
  display: block;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.active { background: #10b981; }
.status-dot.disabled { background: #ef4444; }

/* User Stats */
.user-stats {
  display: flex;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563eb;
}

.stat-key {
  font-size: 20rpx;
  color: #9ca3af;
}

/* Actions */
.user-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dispatch-row {
  display: flex;
  gap: 12rpx;
}

.dispatch-input {
  flex: 1;
  height: 68rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.dispatch-btn {
  width: 140rpx;
  height: 68rpx;
  background: #eff6ff;
  color: #2563eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.toggle-btn {
  width: 100%;
  height: 68rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.toggle-btn.disable {
  background: #fef2f2;
  color: #ef4444;
}

.toggle-btn.enable {
  background: #f0fdf4;
  color: #059669;
}

.reset-btn {
  width: 100%;
  height: 68rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  background: #fff7ed;
  color: #c2410c;
}
