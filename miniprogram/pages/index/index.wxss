/* pages/index/index.wxss */
page {
  background: #f0f2f7;
  min-height: 100vh;
}

.page {
  padding-bottom: 40rpx;
}

/* Hero */
.hero {
  position: relative;
  background: linear-gradient(135deg, #2563eb 0%, #1e40af 60%, #7c3aed 100%);
  padding: 60rpx 36rpx 50rpx;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: 40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-greeting {
  display: flex;
  flex-direction: column;
}

.hero-hello {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.hero-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 4rpx;
}

.admin-badge {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  backdrop-filter: blur(4px);
  margin-top: 10rpx;
}

.hero-dept {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.hero-stats {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  gap: 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.3);
}

/* Alert */
.alert {
  display: flex;
  align-items: center;
  margin: 24rpx 24rpx 0;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  gap: 16rpx;
}

.alert-warn {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
}

.alert-danger {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
}

.alert-icon {
  font-size: 36rpx;
}

.alert-body {
  display: flex;
  flex-direction: column;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.alert-desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* Section */
.section {
  margin: 24rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-date {
  font-size: 24rpx;
  color: #9ca3af;
}

/* Quick Grid */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 10rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.quick-item:active {
  opacity: 0.7;
}

.quick-item.disabled {
  opacity: 0.4;
}

.quick-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon-wrap.blue { background: #eff6ff; }
.quick-icon-wrap.purple { background: #f5f3ff; }
.quick-icon-wrap.green { background: #f0fdf4; }
.quick-icon-wrap.orange { background: #fff7ed; }

.quick-icon {
  width: 48rpx;
  height: 48rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

/* Room Card */
.room-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.room-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
}

.room-row.has-divider {
  border-bottom: 1rpx solid #f3f4f6;
}

.room-row:active {
  background: #f9fafb;
}

.room-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.room-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.room-dot.free { background: #10b981; }
.room-dot.busy { background: #f59e0b; }

.room-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.room-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-free {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

.status-busy {
  font-size: 24rpx;
  color: #6b7280;
}

.row-arrow {
  font-size: 32rpx;
  color: #d1d5db;
}
