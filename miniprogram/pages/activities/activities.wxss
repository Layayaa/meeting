/* pages/activities/activities.wxss */
page {
  background: #f0f2f7;
  min-height: 100vh;
}

.page {
  padding: 24rpx 24rpx 60rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.retry-btn {
  margin-top: 28rpx;
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #2563eb;
  color: #fff;
  font-size: 26rpx;
  border: none;
}

/* Activity Card */
.activity-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.card-header {
  margin-bottom: 20rpx;
}

.card-tag {
  display: inline-block;
  background: #eff6ff;
  color: #2563eb;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
  letter-spacing: 1px;
}

.activity-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.4;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.meta-icon {
  font-size: 26rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #6b7280;
}

.desc-text {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin: 16rpx 0;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 10rpx;
}

/* QR Code */
.qr-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  margin: 20rpx 0;
  background: #fafafa;
  border-radius: 14rpx;
  border: 1rpx dashed #e5e7eb;
}

.qr-image {
  width: 280rpx;
  height: 280rpx;
}

.qr-hint {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 14rpx;
  text-align: center;
}

/* Card Actions */
.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: #2563eb;
  color: #fff;
}

.action-btn.secondary {
  background: #f3f4f6;
  color: #374151;
}
